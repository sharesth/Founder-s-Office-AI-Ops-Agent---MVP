# ── LLM Provider (Google Gemini) ────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── Database ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./founders_ops.db

# ── FAISS ──────────────────────────────────────────────────
FAISS_INDEX_PATH=./faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App ────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
